# Copy to e2e/.env and fill in your sandbox folder (short .mp4/.mkv clips are fine).
MAIZEVIEW_TEST_LIB=C:\Users\you\maizeview-e2e-lib

# Isolated SQLite for E2E — never touches your real library.
MAIZEVIEW_DB_PATH=

# WebView2 CDP endpoint (Windows). Default port 9222.
CDP_URL=http://127.0.0.1:9222

# Set to 1 to let Playwright launch `npm run tauri dev` automatically.
# Otherwise run `npm run e2e:app` in a separate terminal first.
E2E_AUTO_START=0
