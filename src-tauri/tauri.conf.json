{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MaizeView",
  "version": "0.3.2",
  "identifier": "io.github.maizemedia.maizeview",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420/catalog.html",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "catalog",
        "title": "MaizeView",
        "url": "catalog.html",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$LOCALDATA/MaizeView/previews/**/*",
          "$APPDATA/MaizeView/previews/**/*",
          "$LOCALDATA/MaizeView/covers/**/*",
          "$APPDATA/MaizeView/covers/**/*"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "lib/libmpv-2.dll": "libmpv-2.dll",
      "lib/libmpv-wrapper.dll": "libmpv-wrapper.dll"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
