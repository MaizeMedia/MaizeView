{
  "name": "maizeview",
  "version": "0.3.2",
  "description": "MaizeView — a local adult video library organizer, tagger, and multi-window player",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "check:hygiene": "node tools/check-repo-hygiene.mjs",
    "tauri": "tauri",
    "e2e:app": "powershell -ExecutionPolicy Bypass -File scripts/e2e-app.ps1",
    "test:e2e": "playwright test -c e2e/playwright.config.ts",
    "test:e2e:smoke": "playwright test -c e2e/playwright.config.ts e2e/tests/full-smoke.spec.ts e2e/tests/catalog.smoke.spec.ts e2e/tests/search-filters.spec.ts",
    "test:e2e:search": "playwright test -c e2e/playwright.config.ts e2e/tests/search-filters.spec.ts",
    "test:e2e:ui": "playwright test -c e2e/playwright.config.ts --ui",
    "test:e2e:report": "playwright show-report e2e/playwright-report"
  },
  "license": "MIT",
  "dependencies": {
    "@lucide/svelte": "^1.23.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-opener": "^2",
    "clsx": "^2.1.1",
    "qrcode": "^1.5.4",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
    "tauri-plugin-libmpv-api": "^0.3.2",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@internationalized/date": "^3.12.2",
    "@playwright/test": "^1.52.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tailwindcss/vite": "^4.3.2",
    "@tauri-apps/cli": "^2",
    "@types/qrcode": "^1.5.6",
    "bits-ui": "^2.18.1",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "tailwindcss": "^4.3.2",
    "typescript": "~5.6.2",
    "vite": "^6.0.3"
  }
}
